<Window x:Class="_20260610_Titkositas.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_20260610_Titkositas.Windows"
        mc:Ignorable="d"
        Title="Titkosít" Height="200" Width="250"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Label Content="Jelszó:" HorizontalAlignment="Right" />
        <!--<TextBox Grid.Column="1" Grid.ColumnSpan="3" Margin="3" Name="PasswordTextBox" />-->
        <local:PlaceHolderesTextBox Grid.Column="1" Grid.ColumnSpan="3" Margin="3" x:Name="PasswordTextBox" />
        <Button Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="10" Name="CryptionButton" Click="CryptionButton_Click">
            <StackPanel>
                <Image Source="/Assets/lakat.png" MaxHeight="64" />
                <Label Content="Titkosítás"
                       HorizontalAlignment="Stretch"
                       HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Button>
        <Button Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="1" Margin="10" Name="DecryptionButton" Click="DecryptionButton_Click">
            <StackPanel>
                <Image Source="/Assets/nyitott lakat.png" MaxHeight="64" />
                <Label Content="Feloldás" HorizontalAlignment="Center" />
            </StackPanel>
        </Button>
    </Grid>
</Window>
