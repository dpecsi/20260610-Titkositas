<Window x:Class="_20260610_Titkositas.Windows.FileOpenForDecryptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_20260610_Titkositas.Windows"
        mc:Ignorable="d"
        Title="FileOpenForDecryptionWindow" Height="200" Width="450"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="150" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <Label Grid.Column="0"
               Grid.Row="0"
               Content="Adja meg az elem helyét:"
               VerticalAlignment="Bottom" />
        <TextBox Grid.Column="0"
                 Grid.Row="1"
                 Margin="5"
                 Background="Beige"
                 Name="FilePathTextBox"/>
        <Button Grid.Column="1"
                Grid.Row="1"
                Content="Tallózás..."
                Margin="5"
                Name="OpenFileButton" Click="OpenFileButton_Click"/>
        <Button Grid.Column="0"
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Content="Feloldás"
                Width="300"
                Height="35"
                Name="CyptionButton" Click="CyptionButton_Click"/>
    </Grid>
</Window>
