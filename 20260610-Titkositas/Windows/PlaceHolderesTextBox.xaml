<UserControl x:Class="_20260610_Titkositas.Windows.PlaceHolderesTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_20260610_Titkositas.Windows"
             mc:Ignorable="d" 
             d:DesignHeight="20" d:DesignWidth="130">
    <Grid>
        <TextBox HorizontalAlignment="Stretch" Name="UserInput" Visibility="Collapsed" LostFocus="UserInput_LostFocus" />
        <TextBox HorizontalAlignment="Stretch" Name="PlaceholderInput" Visibility="Visible" GotFocus="PlaceholderInput_GotFocus" Text="{Binding Path=PlaceholderText}" Foreground="Gray" VerticalContentAlignment="Center" />
    </Grid>
</UserControl>
